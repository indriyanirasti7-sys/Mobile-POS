<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Icon Kategori -->
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/kategori"
            android:padding="8dp"
            android:background="@drawable/bg_gradient_header"
            app:tint="@color/text_on_primary" />

        <!-- Nama Kategori -->
        <TextView
            android:id="@+id/tvNamaKategori"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nama Kategori"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="14dp" />

        <!-- Layout Aksi untuk Edit dan Hapus (dibungkus agar bisa disembunyikan jika bukan admin) -->
        <LinearLayout
            android:id="@+id/layoutAksiKategori"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="visible">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditKategori"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="70dp"
                android:layout_height="36dp"
                android:text="Edit"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHapusKategori"
                android:layout_width="85dp"
                android:layout_height="36dp"
                android:text="Hapus"
                android:textSize="12sp"
                android:textColor="@color/text_on_primary"
                app:backgroundTint="@color/error"
                app:cornerRadius="8dp" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>