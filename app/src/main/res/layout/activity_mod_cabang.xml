<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Tombol Kembali di Pojok Kiri Atas -->
        <ImageView
            android:id="@+id/btnKembali"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Kembali"
            android:layout_marginBottom="8dp" />

        <!-- Judul Halaman -->
        <TextView
            android:id="@+id/tvJudulModCabang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tambah Cabang"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp" />

        <!-- CardView untuk membungkus form -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Field Nama Cabang -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilNamaCabang"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxStrokeColor="@color/primary"
                    app:hintTextColor="@color/primary"
                    app:errorEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNamaCabang"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nama Cabang"
                        android:inputType="textPersonName"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Field Alamat Cabang -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilAlamatCabang"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxStrokeColor="@color/primary"
                    app:hintTextColor="@color/primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAlamatCabang"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Alamat Cabang"
                        android:inputType="textPostalAddress"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Field Telepon Cabang -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTeleponCabang"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxStrokeColor="@color/primary"
                    app:hintTextColor="@color/primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTeleponCabang"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Telepon Cabang"
                        android:inputType="phone"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Field Penanggung Jawab -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPjCabang"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxStrokeColor="@color/primary"
                    app:hintTextColor="@color/primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPjCabang"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Penanggung Jawab"
                        android:inputType="textPersonName"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressSimpanCabang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            android:indeterminateTint="@color/primary" />

        <!-- Tombol Simpan Cabang -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSimpanCabang"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Simpan Cabang"
            android:textSize="16sp"
            android:textColor="@color/text_on_primary"
            app:cornerRadius="12dp"
            android:backgroundTint="@color/primary" />

    </LinearLayout>
</ScrollView>