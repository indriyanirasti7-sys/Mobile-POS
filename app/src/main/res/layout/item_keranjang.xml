<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="2dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <!-- Informasi Produk -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaProdukKeranjang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Produk"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvHargaKeranjang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp0"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Tombol Kontrol Qty -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnKurangQty"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="-"
                android:textSize="16sp"
                android:padding="0dp" />

            <TextView
                android:id="@+id/tvQtyKeranjang"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="1"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center" />

            <Button
                android:id="@+id/btnTambahQty"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="+"
                android:textSize="16sp"
                android:padding="0dp" />

        </LinearLayout>

        <!-- Tombol Hapus -->
        <ImageButton
            android:id="@+id/btnHapusItem"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/hapus"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginStart="4dp"
            app:tint="@color/error" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvSubtotalKeranjang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Subtotal: Rp0"
        android:textSize="11sp"
        android:textColor="@color/primary"
        android:textStyle="bold"
        android:gravity="end"
        android:paddingHorizontal="12dp"
        android:paddingBottom="8dp" />

</com.google.android.material.card.MaterialCardView>