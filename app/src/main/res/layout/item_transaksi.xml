<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:foreground="?attr/selectableItemBackgroundBorderless"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Product Image -->
        <ImageView
            android:id="@+id/ivFotoProduk"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@color/primary_light"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery" />

        <!-- Product Name -->
        <TextView
            android:id="@+id/tvNamaProduk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Nama Produk"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />

        <!-- Price -->
        <TextView
            android:id="@+id/tvHargaProduk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Rp 0"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-bold" />

        <!-- Stock badge -->
        <TextView
            android:id="@+id/tvStokProduk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_tab_unselected"
            android:paddingStart="6dp"
            android:paddingTop="2dp"
            android:paddingEnd="6dp"
            android:paddingBottom="2dp"
            android:text="Stok: 0"
            android:textColor="@color/text_secondary"
            android:textSize="10sp" />

        <!-- Add button -->
        <Button
            android:id="@+id/btnTambahProduk"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="@drawable/bg_button_primary"
            android:text="+ Tambah"
            android:textColor="@color/white"
            android:textSize="11sp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>