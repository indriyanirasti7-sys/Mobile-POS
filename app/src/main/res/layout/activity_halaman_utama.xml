<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f7fa"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp"
            android:layout_marginTop="30dp">

            <TextView
                android:id="@+id/txtGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selamat Malam, Rasti"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#2c3e50"/>

            <TextView
                android:id="@+id/txtTanggal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08 Januari 2026"
                android:textSize="14sp"
                android:textColor="#7f8c8d"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- CARD ESTIMASI -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardEstimasi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- TITLE -->
                <TextView
                    android:id="@+id/txtEstimasi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estimasi Hari Ini"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <!-- NOMINAL -->
                <TextView
                    android:id="@+id/txtNominal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp. 10.000"
                    android:textColor="#000000"
                    android:layout_marginLeft="265dp"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="-25dp"/>

                <!-- TRANSAKSI & LAPORAN -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                    <!-- TRANSAKSI -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardTransaksi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/imgTransaksi"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:src="@drawable/transaksi"/>

                            <TextView
                                android:id="@+id/txtTransaksi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Transaksi"
                                android:textStyle="bold"
                                android:textColor="#2c3e50"
                                android:layout_marginTop="8dp"/>
                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <!-- LAPORAN -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardLaporan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/imgLaporan"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:src="@drawable/laporan"/>

                            <TextView
                                android:id="@+id/txtLaporan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Laporan"
                                android:textStyle="bold"
                                android:textColor="#2c3e50"
                                android:layout_marginTop="8dp"/>
                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- BARIS AKUN LAYANAN TAMBAHAN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="19dp">

            <!-- AKUN -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAkun"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/imgAkun"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/akun"/>

                    <TextView
                        android:id="@+id/txtAkun"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Akun"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- LAYANAN -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLayanan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/imgProduk"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/produk"/>

                    <TextView
                        android:id="@+id/txtProduk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Produk"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- TAMBAHAN -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTambahan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/imgKategori"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/kategori"/>

                    <TextView
                        android:id="@+id/txtKategori"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kategori"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- BARIS PEGAWAI CABANG PRINTER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- PEGAWAI -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPegawai"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/imgPegawai"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/pegawai"/>

                    <TextView
                        android:id="@+id/txtPegawai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pegawai"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- CABANG -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCabang"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/imgCabang"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/cabang"/>

                    <TextView
                        android:id="@+id/txtCabang"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cabang"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- PRINTER -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPrinter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/imgPrinter"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/printer"/>

                    <TextView
                        android:id="@+id/txtPrinter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Printer"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</ScrollView>