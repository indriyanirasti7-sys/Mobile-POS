<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SelarasPOS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>

        <!-- Text Colors (COKLAT TUA) -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primary_dark</item>

        <!-- Bottom Navigation -->
        <item name="bottomNavigationStyle">@style/Widget.SelarasPOS.BottomNavigation</item>
    </style>

    <!-- Bottom Navigation Style -->
    <style name="Widget.SelarasPOS.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemBackground">@color/surface_variant</item>
        <item name="itemIconTint">@color/text_secondary</item>
        <item name="itemTextColor">@color/text_secondary</item>
    </style>
</resources>