<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbarTrx"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/primary"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnKembali"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_on_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Transaksi"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_on_primary"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tvNamaKasir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kasir"
            android:textSize="13sp"
            android:textColor="#CCFFFFFF" />

        <TextView
            android:id="@+id/tvCabangTrx"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"
            android:textSize="13sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- KIRI: Daftar Produk -->
    <LinearLayout
        android:id="@+id/layoutKiriTrx"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/background_light"
        app:layout_constraintTop_toBottomOf="@id/toolbarTrx"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/dividerTrx"
        app:layout_constraintWidth_percent="0.60">

        <!-- Search Produk -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSearchTrx"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="10dp"
            android:hint="Cari produk..."
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearchTrx"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Chip Kategori -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="10dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupKategori"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:chipSpacing="8dp" />
        </HorizontalScrollView>

        <!-- Grid Produk -->
        <TextView
            android:id="@+id/tvEmptyProdukTrx"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tidak ada produk"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="40dp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvProdukTrx"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="6dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:id="@+id/dividerTrx"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/toolbarTrx"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/layoutKiriTrx"
        app:layout_constraintEnd_toStartOf="@id/layoutKananTrx" />

    <!-- KANAN: Keranjang & Pembayaran -->
    <LinearLayout
        android:id="@+id/layoutKananTrx"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/surface"
        app:layout_constraintTop_toBottomOf="@id/toolbarTrx"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/dividerTrx">

        <!-- Header Keranjang -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="@color/surface"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🛒 Keranjang"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvJumlahItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 item"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- List Keranjang -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvKeranjang"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Footer Total & Bayar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="@color/surface"
            android:elevation="8dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TOTAL"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvTotalKeranjang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBayar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="💳 BAYAR SEKARANG"
                android:textSize="15sp"
                android:textColor="@color/text_on_primary"
                android:layout_marginTop="10dp"
                app:backgroundTint="@color/primary"
                app:cornerRadius="14dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>